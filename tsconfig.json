{
  "compilerOptions": {
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "es2022",
    "sourceMap": true,

    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,

    "esModuleInterop": true,
    "resolveJsonModule": true
  },

  "compileOnSave": true,

  "include": [
    "src"
  ]
}